# PostgreSQL (Supabase) — connection strings em Project Settings > Database > Connect
DATABASE_URL="postgresql://postgres:[password]@[pooler-host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Segredo usado para assinar os cookies de sessão (mínimo 32 caracteres aleatórios)
AUTH_SECRET=""

# API Pública DataJud (CNJ) — usada apenas pelo worker
DATAJUD_API_KEY=""

# Bot do Telegram — criado com @BotFather
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# Intervalo em ms entre consultas à DataJud no worker (padrão: 1500)
WORKER_DELAY_MS="1500"
